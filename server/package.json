{
  "name": "banking-ledger-backend",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "nest start --watch",
    "clean": "rm -rf dist coverage",
    "build": "prisma generate --schema=../prisma/schema.prisma && nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "bun run typecheck",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand --forceExit",
    "test:integration": "jest --config ./test/jest-integration.json --runInBand --forceExit",
    "test:integration:db": "jest --config ./test/jest-integration.json --runInBand --forceExit",
    "check/ci": "bun run clean && bun run build && bun run lint && bun run test && bun run test:integration && bun run test:e2e"
  },
  "dependencies": {
    "@banking/proto": "workspace:*",
    "@grpc/grpc-js": "^1",
    "@grpc/proto-loader": "^0.7",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "10",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "10",
    "@nestjs/platform-express": "10",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "joi": "^18.2.1",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^6.9.14",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "10",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^6.4.15",
    "jest": "^29.5.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}

