# --- INFRASTRUCTURE (DOCKER / COMPOSE) ---
DB_NAME=banking_ledger
DB_USER=banking_user
DB_PASSWORD=banking_password
DB_PORT=5432
REDIS_PORT=6379

# --- HTTP MAIN SERVICE (server) ---
PORT=3000
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173
DATABASE_URL="postgresql://banking_user:banking_password@localhost:5432/banking_ledger"
JWT_ACCESS_SECRET=change-me-access-secret-with-at-least-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-with-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
REDIS_HOST=localhost
OPERATIONS_GRPC_URL=localhost:50051

# --- gRPC OPERATIONS SERVICE (packages/banking-operations-service) ---
OPERATIONS_GRPC_HOST=0.0.0.0
OPERATIONS_GRPC_PORT=50051
OPERATIONS_DATABASE_URL="postgresql://banking_user:banking_password@localhost:5432/banking_ledger?connection_limit=3"
OPERATIONS_EXCHANGE_RATES='{"USD:IDR":"15500","SGD:IDR":"11500","EUR:IDR":"16800","EUR:USD":"1.08","SGD:USD":"0.74"}'
BREVO_API_KEY=your-brevo-api-key
BREVO_API_BASE_URL=https://api.brevo.com/v3
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM=noreply@boyblanco.my.id
LOG_LEVEL=info

